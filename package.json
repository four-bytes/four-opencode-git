    "lint:ts": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.15.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "opencode": {
    "type": "plugin"
  }
}
